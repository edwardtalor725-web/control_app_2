{% extends "base.html" %}
{% block title %}Дашборд{% endblock %}

{% block content %}
<div class="mobile-container">
    <!-- Быстрые действия -->
    <div class="d-flex justify-content-between mb-4">
        <button class="mobile-btn mobile-btn-primary me-2" onclick="location.href='/operations'">
            <i class="fas fa-plus me-2"></i>Добавить операцию
        </button>
        <button class="mobile-btn" onclick="location.href='/reports'" style="background:var(--light-color);color:var(--dark-color);">
            <i class="fas fa-chart-bar me-2"></i>Отчеты
        </button>
    </div>

    <!-- Метрики в сетке -->
    <div class="metrics-grid">
        <div class="metric-card income">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size: 0.9rem; color: #666; margin-bottom: 5px;">
                        <i class="fas fa-arrow-up me-1"></i>Доходы
                    </div>
                    <div class="mobile-h2 text-success">{{ "%.0f"|format(income) }} ₽</div>
                </div>
                <div class="action-icon action-add" style="background: #28a745;">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
            </div>
        </div>

        <div class="metric-card expense">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size: 0.9rem; color: #666; margin-bottom: 5px;">
                        <i class="fas fa-arrow-down me-1"></i>Расходы
                    </div>
                    <div class="mobile-h2 text-danger">{{ "%.0f"|format(expense) }} ₽</div>
                </div>
                <div class="action-icon" style="background: #dc3545;">
                    <i class="fas fa-shopping-cart"></i>
                </div>
            </div>
        </div>

        <div class="metric-card profit">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size: 0.9rem; color: #666; margin-bottom: 5px;">
                        <i class="fas fa-chart-line me-1"></i>Прибыль
                    </div>
                    <div class="mobile-h2 text-info">{{ "%.0f"|format(profit) }} ₽</div>
                </div>
                <div class="action-icon" style="background: #17a2b8;">
                    <i class="fas fa-coins"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- График расходов (мобильная версия) -->
    <div class="mobile-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mobile-h4 mb-0">Расходы по категориям</h5>
            <span class="badge bg-light text-dark">
                <i class="fas fa-filter me-1"></i>Месяц
            </span>
        </div>

        <!-- Простая круговая диаграмма -->
        <div class="text-center">
            <canvas id="expenseChart" height="250"></canvas>
        </div>

        <div class="swipe-indicator">
            <i class="fas fa-arrows-left-right me-1"></i>Свайпайте для деталей
        </div>
    </div>

    <!-- Последние операции -->
    <div class="mobile-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mobile-h4 mb-0">Последние операции</h5>
            <a href="/operations" class="btn btn-sm btn-outline-primary">
                Все <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="table-responsive-mobile">
            <table class="mobile-table">
                <thead>
                    <tr>
                        <th style="width: 30%;">Дата</th>
                        <th style="width: 20%;">Тип</th>
                        <th style="width: 30%;">Категория</th>
                        <th style="width: 20%;" class="text-end">Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    {% for op in operations[:5] %}
                    <tr onclick="location.href='/operations'" style="cursor: pointer;">
                        <td>{{ op.op_date if op.op_date else op.date }}</td>
                        <td>
                            <span class="status-badge {{ 'status-income' if op.type == 'income' else 'status-expense' }}">
                                <i class="fas {{ 'fa-arrow-up me-1' if op.type == 'income' else 'fa-arrow-down me-1' }}"></i>
                                {{ 'Доход' if op.type == 'income' else 'Расход' }}
                            </span>
                        </td>
                        <td>{{ op.category[:15] }}{% if op.category|length > 15 %}...{% endif %}</td>
                        <td class="text-end {{ 'text-success' if op.type == 'income' else 'text-danger' }}">
                            <strong>{{ "%.0f"|format(op.amount) }} ₽</strong>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if operations|length == 0 %}
        <div class="text-center py-4">
            <i class="fas fa-receipt fa-2x text-muted mb-3"></i>
            <p class="text-muted">Нет операций</p>
        </div>
        {% endif %}
    </div>

    <!-- Счета -->
    <div class="mobile-card">
        <h5 class="mobile-h4 mb-3">Счета</h5>
        <div class="row">
            {% for acc in accounts %}
            <div class="col-6 mb-3">
                <div class="p-3 border rounded" style="background: #f8f9fa;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div style="font-size: 0.9rem; color: #666;">{{ acc.name }}</div>
                            <div class="mobile-h3">{{ "%.0f"|format(acc.balance) }} ₽</div>
                        </div>
                        <span class="badge {{ 'bg-success' if acc.balance >= acc.min_balance else 'bg-warning' }}">
                            {{ 'OK' if acc.balance >= acc.min_balance else 'Low' }}
                        </span>
                    </div>
                    {% if acc.min_balance and acc.min_balance > 0 %}
                    <div class="mt-2" style="font-size: 0.8rem; color: #999;">
                        <i class="fas fa-exclamation-circle me-1"></i>Мин: {{ "%.0f"|format(acc.min_balance) }} ₽
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <!-- Быстрые действия панель -->
    <div class="mobile-card">
        <h5 class="mobile-h4 mb-3">Быстрые действия</h5>
        <div class="row g-2">
            <div class="col-6">
                <button class="mobile-btn" style="background: #e3f2fd; color: #1976d2;"
                        onclick="location.href='/operations?type=income'">
                    <i class="fas fa-plus-circle me-2"></i>Доход
                </button>
            </div>
            <div class="col-6">
                <button class="mobile-btn" style="background: #ffebee; color: #d32f2f;"
                        onclick="location.href='/operations?type=expense'">
                    <i class="fas fa-minus-circle me-2"></i>Расход
                </button>
            </div>
            <div class="col-6">
                <button class="mobile-btn" style="background: #f3e5f5; color: #7b1fa2;"
                        onclick="location.href='/reports'">
                    <i class="fas fa-file-invoice me-2"></i>Отчет
                </button>
            </div>
            <div class="col-6">
                <button class="mobile-btn" style="background: #e8f5e8; color: #388e3c;"
                        onclick="location.href='/calendar'">
                    <i class="fas fa-calendar-alt me-2"></i>Календарь
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
    // Простой график для мобильных
    fetch('/api/expenses_by_category')
        .then(response => response.json())
        .then(data => {
            if (data.categories.length > 0) {
                const ctx = document.getElementById('expenseChart').getContext('2d');
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: data.categories,
                        datasets: [{
                            data: data.amounts,
                            backgroundColor: [
                                '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0',
                                '#9966FF', '#FF9F40', '#8AC926', '#1982C4'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    boxWidth: 12,
                                    font: {
                                        size: 11
                                    },
                                    padding: 15
                                }
                            }
                        }
                    }
                });
            } else {
                document.getElementById('expenseChart').parentElement.innerHTML = `
                <div class="text-center py-4">
                    <i class="fas fa-chart-pie fa-2x text-muted mb-3"></i>
                    <p class="text-muted">Нет данных для графика</p>
                </div>
            `;
            }
        })
        .catch(error => {
            console.error('Error loading chart:', error);
            document.getElementById('expenseChart').parentElement.innerHTML = `
            <div class="text-center py-4">
                <i class="fas fa-exclamation-triangle fa-2x text-warning mb-3"></i>
                <p class="text-muted">Не удалось загрузить график</p>
            </div>
        `;
        });

    // Обновление данных каждые 30 секунд
    setInterval(() => {
        fetch('/')
            .then(() => console.log('Dashboard updated'))
            .catch(() => console.log('Update failed'));
    }, 30000);
</script>
{% endblock %}